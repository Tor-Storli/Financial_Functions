# ── fin_functions: Annuity function tests ─────────────────────────────────────
# Tests match Excel examples from Microsoft support documentation.
# Format: query returns a value that is compared to expected result.
# NULL tests verify graceful failure on bad input (no crash).

statement ok
LOAD '__BUILD_DIRECTORY__/fin_functions.duckdb_extension';

# ── FV ────────────────────────────────────────────────────────────────────────

# Excel example: FV(0.06/12, 10, -200, -500, true) = 2581.4
query R
SELECT ROUND(fv(0.06/12, 10.0, -200.0, -500.0, true), 2);
----
2581.4

# Excel example: FV(12%/12, 12, -1000, 0, false) = 12682.5
query R
SELECT ROUND(fv(0.12/12, 12.0, -1000.0, 0.0, false), 2);
----
12682.5

# Zero rate: FV = -(pv + pmt * nper)
query R
SELECT ROUND(fv(0.0, 10.0, -100.0, -500.0, false), 2);
----
1500.0

# ── PV ────────────────────────────────────────────────────────────────────────

# Excel example: PV(8%/12, 20*12, 500, 0, false) = -59777.15
query R
SELECT ROUND(pv(0.08/12, 240.0, 500.0, 0.0, false), 2);
----
-59777.15

# ── PMT ───────────────────────────────────────────────────────────────────────

# Excel example: PMT(8%/12, 10, 10000, 0, false) = -1037.03
query R
SELECT ROUND(pmt(0.08/12, 10.0, 10000.0, 0.0, false), 2);
----
-1037.03

# Zero rate: PMT = -(pv + fv) / nper
query R
SELECT ROUND(pmt(0.0, 12.0, 1200.0, 0.0, false), 2);
----
-100.0

# ── IPMT ──────────────────────────────────────────────────────────────────────

# Excel example: IPMT(10%/12, 1, 3, 8000, 0, false) = -66.67
query R
SELECT ROUND(ipmt(0.10/12, 1.0, 3.0, 8000.0, 0.0, false), 2);
----
-66.67

# Guard: per = 0 → NULL
query R
SELECT ipmt(0.10/12, 0.0, 12.0, 10000.0, 0.0, false) IS NULL;
----
true

# Guard: per > nper → NULL
query R
SELECT ipmt(0.10/12, 99.0, 12.0, 10000.0, 0.0, false) IS NULL;
----
true

# Guard: nper = 0 → NULL
query R
SELECT ipmt(0.10/12, 1.0, 0.0, 10000.0, 0.0, false) IS NULL;
----
true

# ── PPMT ──────────────────────────────────────────────────────────────────────

# Excel example: PPMT(10%/12, 1, 2*12, 2000, 0, false) = -75.62
query R
SELECT ROUND(ppmt(0.10/12, 1.0, 24.0, 2000.0, 0.0, false), 2);
----
-75.62

# Guard: per = 0 → NULL
query R
SELECT ppmt(0.10/12, 0.0, 12.0, 10000.0, 0.0, false) IS NULL;
----
true

# ── CUMIPMT ───────────────────────────────────────────────────────────────────

# Excel example: CUMIPMT(9%/12, 30*12, 125000, 1, 1, false) = -937.5
query R
SELECT ROUND(cumipmt(0.09/12, 360.0, 125000.0, 1.0, 1.0, false), 2);
----
-937.5

# Guard: start > end → NULL
query R
SELECT cumipmt(0.09/12, 360.0, 125000.0, 5.0, 1.0, false) IS NULL;
----
true

# Guard: start = 0 → NULL
query R
SELECT cumipmt(0.09/12, 360.0, 125000.0, 0.0, 12.0, false) IS NULL;
----
true

# Guard: end > nper → NULL
query R
SELECT cumipmt(0.09/12, 12.0, 125000.0, 1.0, 999.0, false) IS NULL;
----
true

# ── CUMPRINC ──────────────────────────────────────────────────────────────────

# Excel example: principal paid in first month
query R
SELECT ROUND(cumprinc(0.09/12, 360.0, 125000.0, 1.0, 1.0, false), 2);
----
-68.28

# Guard: start > end → NULL
query R
SELECT cumprinc(0.09/12, 360.0, 125000.0, 10.0, 1.0, false) IS NULL;
----
true

# ── NPER ──────────────────────────────────────────────────────────────────────

# Excel example: NPER(12%/12, -100, -1000, 10000, true) = 59.67
query R
SELECT ROUND(nper(0.12/12, -100.0, -1000.0, 10000.0, true), 2);
----
59.67

# ── RATE ──────────────────────────────────────────────────────────────────────

# Excel example: RATE(48, -200, 8000, 0, false, 0.1) * 12 ≈ 9.24%
query R
SELECT ROUND(rate(48.0, -200.0, 8000.0, 0.0, false, 0.1) * 12, 4);
----
0.0924

# Guard: nper = 0 → NULL
query R
SELECT rate(0.0, -200.0, 8000.0, 0.0, false, 0.1) IS NULL;
----
true

# ── ISPMT ─────────────────────────────────────────────────────────────────────

# Excel example: ISPMT(10%/12, 1, 36, 8000000) = -66666.67
query R
SELECT ROUND(ispmt(0.10/12, 1.0, 36.0, 8000000.0), 2);
----
-66666.67

# Guard: per = 0 → NULL
query R
SELECT ispmt(0.05, 0.0, 12.0, 10000.0) IS NULL;
----
true

# Guard: per > nper → NULL
query R
SELECT ispmt(0.05, 99.0, 12.0, 10000.0) IS NULL;
----
true
