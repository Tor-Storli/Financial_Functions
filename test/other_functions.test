# ── fin_functions: Depreciation, Coupon, Bond, Misc tests ────────────────────

statement ok
LOAD '__BUILD_DIRECTORY__/fin_functions.duckdb_extension';

# ══════════════════════════════════════════════════════════════════════════════
# DEPRECIATION
# ══════════════════════════════════════════════════════════════════════════════

# ── SLN ───────────────────────────────────────────────────────────────────────
query R
SELECT sln(30000.0, 7500.0, 10.0);
----
2250.0

# Guard: life = 0 → NULL
query R
SELECT sln(30000.0, 7500.0, 0.0) IS NULL;
----
true

# ── SYD ───────────────────────────────────────────────────────────────────────
query R
SELECT ROUND(syd(30000.0, 7500.0, 10.0, 1.0), 2);
----
4090.91

# ── DB ────────────────────────────────────────────────────────────────────────
query R
SELECT ROUND(db(1000000.0, 100000.0, 6.0, 1.0, 7.0), 2);
----
186083.33

# ── DDB ───────────────────────────────────────────────────────────────────────
query R
SELECT ddb(2400.0, 300.0, 10.0, 1.0, 2.0);
----
480.0

# ── VDB ───────────────────────────────────────────────────────────────────────
query R
SELECT ROUND(vdb(2400.0, 300.0, 10.0*12, 0.0, 1.0, 2.0, 0.0), 2);
----
40.0

query R
SELECT ROUND(vdb(2400.0, 300.0, 10.0, 0.0, 1.0, 2.0, 0.0), 2);
----
480.0

# ── AMORDEGRC ─────────────────────────────────────────────────────────────────
# Excel example: period 1 = 776
query R
SELECT ROUND(amordegrc(2400.0, 39679.0, 39813.0, 300.0, 1.0, 0.15, 1.0), 2);
----
776.0

# Guard: rate = 0 → NULL
query R
SELECT amordegrc(2400.0, 0.0, 365.0, 300.0, 1.0, 0.0, 1.0) IS NULL;
----
true

# ── AMORLINC ──────────────────────────────────────────────────────────────────
query R
SELECT ROUND(amorlinc(2400.0, 39679.0, 39813.0, 300.0, 1.0, 0.15, 1.0), 2);
----
360.0

# ══════════════════════════════════════════════════════════════════════════════
# COUPON DATE FUNCTIONS
# ══════════════════════════════════════════════════════════════════════════════

# ── COUPDAYBS ─────────────────────────────────────────────────────────────────
query R
SELECT coupdaybs('2011-01-25', '2011-11-15', 2.0, 1.0);
----
71.0

# Guard: settlement >= maturity → NULL
query R
SELECT coupdaybs('2025-01-01', '2020-01-01', 2.0, 1.0) IS NULL;
----
true

# Guard: settlement = maturity → NULL
query R
SELECT coupdaybs('2020-01-01', '2020-01-01', 2.0, 1.0) IS NULL;
----
true

# Guard: bad date string → NULL
query R
SELECT coupdaybs('not-a-date', '2020-01-01', 2.0, 1.0) IS NULL;
----
true

# ── COUPDAYS ──────────────────────────────────────────────────────────────────
query R
SELECT coupdays('2011-01-25', '2011-11-15', 2.0, 1.0);
----
181.0

# ── COUPDAYSNC ────────────────────────────────────────────────────────────────
query R
SELECT coupdaysnc('2011-01-25', '2011-11-15', 2.0, 1.0);
----
110.0

# ── COUPNUM ───────────────────────────────────────────────────────────────────
query R
SELECT coupnum('2007-01-25', '2008-11-15', 2.0, 1.0);
----
4.0

# ══════════════════════════════════════════════════════════════════════════════
# BOND & SECURITY FUNCTIONS
# ══════════════════════════════════════════════════════════════════════════════

# ── PRICE ─────────────────────────────────────────────────────────────────────
query R
SELECT ROUND(price('2008-02-15', '2017-11-15', 0.0575, 0.065, 100.0, 2.0, 0.0), 2);
----
94.63

# Guard: settlement >= maturity → NULL
query R
SELECT price('2020-01-01', '2010-01-01', 0.05, 0.06, 100.0, 2.0, 0.0) IS NULL;
----
true

# Guard: bad date → NULL
query R
SELECT price('bad-date', '2017-11-15', 0.0575, 0.065, 100.0, 2.0, 0.0) IS NULL;
----
true

# ── YIELD ─────────────────────────────────────────────────────────────────────
query R
SELECT ROUND(yield('2008-02-15', '2016-11-15', 0.0575, 95.04287, 100.0, 2.0, 0.0), 4);
----
0.065

# ── YIELDDISC ─────────────────────────────────────────────────────────────────
query R
SELECT ROUND(yielddisc('2008-02-16', '2008-03-01', 99.795, 100.0, 2.0), 4);
----
0.0528

# ── PRICEDISC ─────────────────────────────────────────────────────────────────
query R
SELECT ROUND(pricedisc('2008-02-16', '2008-03-01', 0.0525, 100.0, 2.0), 3);
----
99.796

# ── INTRATE ───────────────────────────────────────────────────────────────────
query R
SELECT ROUND(intrate('2008-02-15', '2008-05-15', 1000000.0, 1014420.0, 2.0), 5);
----
0.05768

# ── RECEIVED ──────────────────────────────────────────────────────────────────
query R
SELECT ROUND(received('2008-02-15', '2008-05-15', 1000000.0, 0.0575, 2.0), 2);
----
1014584.65

# ── DURATION ──────────────────────────────────────────────────────────────────
query R
SELECT ROUND(duration('2008-01-01', '2016-01-01', 0.08, 0.09, 2.0, 1.0), 4);
----
5.9938

# ── MDURATION ─────────────────────────────────────────────────────────────────
query R
SELECT ROUND(mduration('2008-01-01', '2016-01-01', 0.08, 0.09, 2.0, 1.0), 4);
----
5.7357

# ── ACCRINTM ──────────────────────────────────────────────────────────────────
query R
SELECT ROUND(accrintm('2008-04-01', '2008-06-15', 0.10, 1000.0, 3.0), 2);
----
20.55

# ── ODDFPRICE ─────────────────────────────────────────────────────────────────
query R
SELECT ROUND(oddfprice('2008-11-11', '2021-03-01', '2008-10-15', '2009-03-01',
    0.0785, 0.0625, 100.0, 2.0, 1.0), 2);
----
113.6

# ── ODDLPRICE ─────────────────────────────────────────────────────────────────
query R
SELECT ROUND(oddlprice('2008-02-07', '2008-06-15', '2007-10-15',
    0.0375, 0.0405, 100.0, 2.0, 0.0), 2);
----
99.88

# ── ODDLYIELD ─────────────────────────────────────────────────────────────────
query R
SELECT ROUND(oddlyield('2008-04-20', '2008-06-15', '2007-12-24',
    0.0375, 99.875, 100.0, 2.0, 0.0), 4);
----
0.0455

# ══════════════════════════════════════════════════════════════════════════════
# MISCELLANEOUS FUNCTIONS
# ══════════════════════════════════════════════════════════════════════════════

# ── EFFECT ────────────────────────────────────────────────────────────────────
query R
SELECT ROUND(effect(0.0525, 4.0), 6);
----
0.053543

# Guard: npery = 0 → NULL
query R
SELECT effect(0.05, 0.0) IS NULL;
----
true

# ── NOMINAL ───────────────────────────────────────────────────────────────────
query R
SELECT ROUND(nominal(0.053543, 4.0), 4);
----
0.0525

# ── DOLLARDE ──────────────────────────────────────────────────────────────────
query R
SELECT dollarde(1.02, 16.0);
----
1.125

# ── DOLLARFR ──────────────────────────────────────────────────────────────────
query R
SELECT dollarfr(1.125, 16.0);
----
1.02

# ── FVSCHEDULE ────────────────────────────────────────────────────────────────
query R
SELECT ROUND(fvschedule(1.0, '0.09,0.11,0.10'), 4);
----
1.3309

# Guard: empty string → NULL
query R
SELECT fvschedule(1.0, '') IS NULL;
----
true

# ── RRI ───────────────────────────────────────────────────────────────────────
query R
SELECT ROUND(rri(96.0, 10000.0, 11000.0), 6);
----
0.000993

# Guard: pv = 0 → NULL
query R
SELECT rri(10.0, 0.0, 1000.0) IS NULL;
----
true

# ── PDURATION ─────────────────────────────────────────────────────────────────
query R
SELECT ROUND(pduration(0.025, 2000.0, 2200.0), 4);
----
3.8599

# ── TBILLPRICE ────────────────────────────────────────────────────────────────
query R
SELECT ROUND(tbillprice('2008-03-31', '2008-06-01', 0.09), 2);
----
98.45

# ── TBILLYIELD ────────────────────────────────────────────────────────────────
query R
SELECT ROUND(tbillyield('2008-03-31', '2008-06-01', 98.45), 4);
----
0.0914

# ── TBILLEQ ───────────────────────────────────────────────────────────────────
query R
SELECT ROUND(tbilleq('2008-03-31', '2008-06-01', 0.0914), 4);
----
0.0942

# Guard: bad settlement date → NULL
query R
SELECT tbilleq('bad-date', '2008-06-01', 0.09) IS NULL;
----
true
