# ── NULL / robustness guards ──────────────────────────────────────────────────

# IRR on all-positive flows has no solution → NULL
query I
SELECT irr('10000,2000,3000') IS NULL;
----
true

# NPV with empty string → NULL
query I
SELECT npv(0.10, '') IS NULL;
----
true

# RATE non-convergence with impossible inputs → NULL
query I
SELECT rate(1.0, -1.0, 1000000.0, 0.0, false, 0.1) IS NULL;
----
true
